# AG-UI Playground - Backend Configuration

# Azure AI Foundry Project Endpoint
# Format: https://<resource-name>.services.ai.azure.com/
FOUNDRY_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/

# Model deployments - match your actual deployment names in the Foundry resource
FOUNDRY_MODEL_CHAT=gpt-4.1-mini
FOUNDRY_MODEL_REASONING=o4-mini

# MCP Server URL (optional - backend works without it)
MCP_SERVER_URL=http://127.0.0.1:8889/mcp
